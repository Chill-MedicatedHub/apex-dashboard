# ============================================================
# Apex Trading Scraper — Configuration
# ============================================================
# 1. Paste your session cookie below (see README.md for how)
# 2. Save this file
# 3. Run: python scraper.py
#
# IMPORTANT: This file contains your login session. Never commit
# it to git or share it. Treat the cookie like a password.
# ============================================================

# Your Apex session cookie. Get this from your browser:
#   F12 → Network → run the report → click the request →
#   Headers → Request Headers → copy the entire "Cookie:" value
APEX_COOKIE=""

# Your Apex user/company IDs (from the request payload you screenshotted)
APEX_USER_ID=10676
APEX_COMPANY_ID=4677

# How many rows to pull per request (max). Increase if you have more sales.
APEX_ROW_LIMIT=5000

# How many days back to pull. 90 = last 3 months.
APEX_DAYS_BACK=90
